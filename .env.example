# Reamaze API credentials (Reamaze dashboard > Settings > API > API Token)
REAMAZE_BRAND=your-subdomain
REAMAZE_EMAIL=you@example.com
REAMAZE_API_TOKEN=your-api-token

# HTTP transport only (build/http.js): shared secret that clients must send as
#   Authorization: Bearer <MCP_AUTH_TOKEN>
# Generate a long random value. The HTTP server refuses to start without it.
# Not needed for the local stdio transport (build/index.js).
MCP_AUTH_TOKEN=

# Optional: HTTP port. Railway injects PORT automatically; defaults to 3000.
PORT=3000
